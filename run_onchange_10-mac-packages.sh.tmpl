{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# mac-packages.yaml hash: {{ include ".chezmoidata/mac-packages.yaml" | sha256sum }}

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.formulae -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

{{ range .packages.services -}}
brew services start {{ . | quote }}
{{ end -}}

{{ end -}}